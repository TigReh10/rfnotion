# ----- App -----
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3000

# ----- Database -----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resumeforge?schema=public

# ----- Redis -----
REDIS_URL=redis://localhost:6379

# ----- Auth -----
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
AUTH_COOKIE_NAME=rf_session

# ----- Google OAuth -----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback

# ----- Email (SMTP) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=ResumeForge AI <no-reply@resumeforge.ai>

# ----- AI providers -----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Optional: point the OpenAI-compatible client at a custom endpoint.
# For local Ollama, set the base URL below and OPENAI_MODEL to a model you have
# pulled (e.g. llama3.1). No API key is required when OPENAI_BASE_URL is set.
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_MODEL=llama3.1
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
AI_PRIMARY_PROVIDER=openai

# ----- Stripe -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ----- Storage (S3-compatible) -----
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=resumeforge-uploads
S3_FORCE_PATH_STYLE=true

# ----- Security -----
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=100
ENCRYPTION_KEY=change-me-base64-32-bytes
